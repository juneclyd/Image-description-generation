import json
import pickle
from pathlib import Path

import torch
import torch.nn as nn
import torchvision as tv
import torchvision.transforms as transforms
from PIL import Image


BASE_DIR = Path(__file__).resolve().parent
DEFAULT_CHECKPOINT_CANDIDATES = [
    BASE_DIR / "caption_model_stage2_checkpoint.pth",
    BASE_DIR / "models" / "caption_model_stage2_checkpoint.pth",
]
DEFAULT_STATE_DICT_CANDIDATES = [
    BASE_DIR / "caption_model_stage2.pth",
    BASE_DIR / "models" / "caption_model_stage2.pth",
]
DEFAULT_VOCAB_CANDIDATES = [
    BASE_DIR / "caption_model_stage2_vocab.pkl",
    BASE_DIR / "models" / "caption_model_stage2_vocab.pkl",
    BASE_DIR / "caption_model_stage2_vocab.json",
    BASE_DIR / "models" / "caption_model_stage2_vocab.json",
]


def _pick_first_existing(paths):
    for path in paths:
        if path.exists():
            return path
    return None


class EncoderCNN(nn.Module):
    def __init__(self, hidden_size: int):
        super().__init__()
        weights = tv.models.ResNet50_Weights.DEFAULT
        resnet = tv.models.resnet50(weights=weights)
        for param in resnet.parameters():
            param.requires_grad_(False)
        modules = list(resnet.children())[:-1]
        self.resnet = nn.Sequential(*modules)
        self.embed = nn.Linear(resnet.fc.in_features, hidden_size)

    def forward(self, images):
        features = self.resnet(images)
        features = features.view(features.size(0), -1)
        return self.embed(features)


class DecoderRNN(nn.Module):
    def __init__(self, embed_size: int, hidden_size: int, vocab_size: int, num_layers: int):
        super().__init__()
        self.embed = nn.Embedding(vocab_size, embed_size)
        self.lstm = nn.LSTM(embed_size, hidden_size, num_layers, batch_first=True)
        self.linear = nn.Linear(hidden_size, vocab_size)

    def forward(self, features, captions):
        embeddings = self.embed(captions[:, :-1])
        h0 = features.unsqueeze(0).repeat(self.lstm.num_layers, 1, 1)
        c0 = torch.zeros_like(h0)
        outputs, _ = self.lstm(embeddings, (h0, c0))
        return self.linear(outputs)


class CaptionModel(nn.Module):
    def __init__(self, embed_size: int, hidden_size: int, vocab_size: int, num_layers: int):
        super().__init__()
        self.encoder = EncoderCNN(hidden_size)
        self.decoder = DecoderRNN(embed_size, hidden_size, vocab_size, num_layers)

    def forward(self, images, captions):
        features = self.encoder(images)
        return self.decoder(features, captions)


def _load_vocab(vocab_path: Path):
    if vocab_path.suffix == ".pkl":
        with vocab_path.open("rb") as file:
            return pickle.load(file)
    with vocab_path.open("r", encoding="utf-8") as file:
        return json.load(file)


def _load_from_full_checkpoint(checkpoint, device):
    vocab = checkpoint["vocab"]
    vocab_size = len(vocab)
    embed_size = checkpoint.get("embed_size", 256)
    hidden_size = checkpoint.get("hidden_size", 512)
    num_layers = checkpoint.get("num_layers", 1)
    max_caption_words = checkpoint.get("max_caption_words", 10)

    model = CaptionModel(embed_size, hidden_size, vocab_size, num_layers).to(device)
    model.load_state_dict(checkpoint["model_state_dict"])
    model.eval()

    return model, vocab, {
        "embed_size": embed_size,
        "hidden_size": hidden_size,
        "num_layers": num_layers,
        "max_caption_words": max_caption_words,
    }


def _load_from_state_dict_only(state_dict, vocab, device):
    embed_size = 256
    hidden_size = 512
    num_layers = 1
    max_caption_words = 10
    vocab_size = len(vocab)

    model = CaptionModel(embed_size, hidden_size, vocab_size, num_layers).to(device)
    model.load_state_dict(state_dict)
    model.eval()

    return model, {
        "embed_size": embed_size,
        "hidden_size": hidden_size,
        "num_layers": num_layers,
        "max_caption_words": max_caption_words,
    }


class Stage2CaptionService:
    def __init__(self, checkpoint_path: Path | None = None, vocab_path: Path | None = None):
        self.device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
        self.transform = transforms.Compose(
            [
                transforms.Resize(256),
                transforms.CenterCrop(224),
                transforms.ToTensor(),
                transforms.Normalize(
                    mean=[0.485, 0.456, 0.406],
                    std=[0.229, 0.224, 0.225],
                ),
            ]
        )

        checkpoint_path = checkpoint_path or _pick_first_existing(DEFAULT_CHECKPOINT_CANDIDATES)
        state_dict_path = _pick_first_existing(DEFAULT_STATE_DICT_CANDIDATES)
        vocab_path = vocab_path or _pick_first_existing(DEFAULT_VOCAB_CANDIDATES)

        if checkpoint_path is not None:
            checkpoint = torch.load(checkpoint_path, map_location=self.device, weights_only=False)
            self.model, self.vocab, self.config = _load_from_full_checkpoint(checkpoint, self.device)
            self.source_path = checkpoint_path
        elif state_dict_path is not None and vocab_path is not None:
            state_dict = torch.load(state_dict_path, map_location=self.device, weights_only=False)
            self.vocab = _load_vocab(vocab_path)
            self.model, self.config = _load_from_state_dict_only(state_dict, self.vocab, self.device)
            self.source_path = state_dict_path
        else:
            raise FileNotFoundError(
                "Не найден checkpoint Stage 2 модели. Нужен либо "
                "`caption_model_stage2_checkpoint.pth`, либо пара "
                "`caption_model_stage2.pth` + `caption_model_stage2_vocab.pkl/json`."
            )

        self.inv_vocab = {idx: word for word, idx in self.vocab.items()}

    @torch.inference_mode()
    def predict(self, image: Image.Image, max_len: int | None = None) -> str:
        max_len = max_len or self.config["max_caption_words"]
        image_tensor = self.transform(image.convert("RGB")).unsqueeze(0).to(self.device)
        features = self.model.encoder(image_tensor)

        hidden = features.unsqueeze(0).repeat(self.model.decoder.lstm.num_layers, 1, 1)
        cell = torch.zeros_like(hidden)
        states = (hidden, cell)
        current = torch.tensor([[self.vocab["<start>"]]], dtype=torch.long, device=self.device)

        generated_words = []
        for _ in range(max_len):
            embeddings = self.model.decoder.embed(current)
            outputs, states = self.model.decoder.lstm(embeddings, states)
            outputs = self.model.decoder.linear(outputs.squeeze(1))
            predicted = outputs.argmax(dim=1)
            predicted_idx = predicted.item()

            if predicted_idx == self.vocab["<end>"]:
                break

            if predicted_idx not in {self.vocab["<start>"], self.vocab["<pad>"]}:
                generated_words.append(self.inv_vocab.get(predicted_idx, "<unk>"))

            current = predicted.unsqueeze(0)

        if not generated_words:
            return "Описание не удалось сгенерировать."

        sentence = " ".join(generated_words)
        return sentence[0].upper() + sentence[1:]

    def info(self):
        return {
            "device": str(self.device),
            "checkpoint": str(self.source_path),
            "vocab_size": len(self.vocab),
            "max_caption_words": self.config["max_caption_words"],
        }
